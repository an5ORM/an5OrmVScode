{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2020",
    "outDir": "dist",
    "lib": ["es2020"],
    "sourceMap": true,
    "strict": true,
    "rootDir": "src",
    "skipLibCheck": true,
    "types": ["node"],
    "typeRoots": ["./node_modules/@types"],
    "ignoreDeprecations": "6.0"
  },
  "exclude": ["node_modules", ".vscode-test"]
}
